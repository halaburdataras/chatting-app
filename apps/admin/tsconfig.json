{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "~lib/*": ["./lib/*"],
      "~hooks/*": ["./hooks/*"],
      "~constants/*": ["./constants/*"],
      "~components/*": ["./components/*"],
      "~providers/*": ["./providers/*"],
      "~types/*": ["./types/*"],
      "~icons/*": ["./assets/icons/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

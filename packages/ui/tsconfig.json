{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist"
  },
  "include": ["src"],
  "paths": {
    "~components/*": ["./src/components/*"],
    "~icons/*": ["./src/icons/*"],
    "~providers/*": ["./src/providers/*"],
    "~types/*": ["./src/types/*"]
  },
  "exclude": ["dist", "build", "node_modules"]
}

{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "env": [
        "DATABASE_URL", 
        "CRYPTO_JS_SECRET_KEY",
        "NEXT_PUBLIC_WS_URL",
        "JWT_SECRET", 
        "JWT_EXPIRES_IN", 
        "FRONTEND_URL", 
        "ADMIN_URL", 
        "WEBSOCKET_URL"
      ],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "generated/**"]
    },
    "build:components": {
  "dependsOn": ["^build"],
  "outputs": ["dist/**"]
},
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

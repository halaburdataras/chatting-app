{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "generated/**"],
      "env": ["DATABASE_URL", "CRYPTO_JS_SECRET_KEY","NODE_ENV", "NEXT_PUBLIC_WS_URL",
      "JWT_SECRET", 
      "JWT_EXPIRES_IN", 
      "FRONTEND_URL", 
      "ADMIN_URL", 
      "WEBSOCKET_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
